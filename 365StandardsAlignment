Write-Output "3.1 Ensure the customer lockbox feature is enabled" >> $filename
#Start-Sleep -Seconds 1.5
get-organizationconfig | select-object -property CustomerLockboxEnabled >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "3.2 Ensure SharePoint Online data classification policies are set up and used" >> $filename
#Start-Sleep -Seconds 1.5
Get-SPOTenant | Select-Object -Property EnableAIPIntegration >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "3.3 Ensure external users are not allowed in Skype or Teams" >> $filename
#Start-Sleep -Seconds 1.5
Get-CsTeamsClientConfiguration | Select-Object -Property AllowGuestUser >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "3.4 Ensure DLP policies are enabled" >> $filename
#Start-Sleep -Seconds 1.5
Get-DlpCompliancePolicy | Select-Object DisplayName,Enabled >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "3.5 Ensure DLP policies are enabled for Microsoft Teams" >> $filename
#Start-Sleep -Seconds 1.5
Get-DlpCompliancePolicy | Select-Object DisplayName,Enabled,Workload >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "3.6 Ensure that external users cannot share files, folders, and sites they do not own" >> $filename
#Start-Sleep -Seconds 1.5
Get-SPOTenant | Select-Object -Property PreventExternalUsersFromResharing >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "3.7 Ensure external file sharing in Teams is enabled for only approved cloud storage services" >> $filename
#Start-Sleep -Seconds 1.5
Get-CsTeamsClientConfiguration | Select-Object -Property AllowDropbox,AllowBox,AllowGoogleDrive,AllowShareFile,AllowEgnyte >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "3.8 Ensure that Microsoft Teams is using OneDrive for Business and SharePoint for meeting recordings" >> $filename
#Start-Sleep -Seconds 1.5
Get-CsTeamsMeetingPolicy -identity global | fl RecordingStorageMode >> $filename
#Read-Host -Prompt "Press any key to continue"

# =============================================
# This is the 4.x series of questions, Email Security
# =============================================
# This section is complete.
# =============================================

Write-Output "4.1 Ensure the Common Attachment Types Filter is enabled" >> $filename
#Start-Sleep -Seconds 1.5
Get-MalwareFilterPolicy | Select-Object -Property ID,FileTypeAction,FileTypes >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "Ensure Exchange Online Spam Policies are set correctly" >> $filename
#Start-Sleep -Seconds 1.5
get-hostedoutboundspamfilterpolicy | Select-Object -Property ID,BccSuspiciousOutboundMail,BccSuspiciousOutboundAdditionalRecipients,NotifyOutboundSpam,NotifyOutboundSpamRecipients >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.2.1 IP Allow Lists are NOT present for Spam" >> $filename
#Start-Sleep -Seconds 1.5
Get-HostedConnectionFilterPolicy | Select-Object Name,IPAllowList >> $filename
Write-Output "Verify that no IP Addresses exist in the list." >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.3 Ensure mail transport rules do not forward email to external domains" >> $filename
#Start-Sleep -Seconds 1.5
Get-TransportRule | Select-Object -Property Name,Description | Format-List >> $filename
Write-Output "Verify that there are no auto-forwarding rules" >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.4 Ensure Automatic Forwarding Options are disabled" >> $filename
#Start-Sleep -Seconds 1.5
Get-RemoteDomain Default | fl AllowedOOFType, AutoForwardEnabled >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.5 Ensure mail transport rules do not whitelist specific domains" >> $filename
#Start-Sleep -Seconds 1.5
Get-TransportRule | Select-Object -Property Name,Description | Format-List >> $filename
Write-Output "Verify that there are no rules that whitelist domains." >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.6 Ensure the Client Rules Forwarding Block is enabled" >> $filename
#Start-Sleep -Seconds 1.5
Get-TransportRule | Select-Object -Property Name,Description | Format-List >> $filename
Write-Output "Verify that one of these blocks auto forwards from internal to external senders" >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.7 Ensure the Advanced Threat Protection Safe Links policy is enabled" >> $filename
#Start-Sleep -Seconds 1.5
get-safelinkspolicy | select-object -property ID,AllowClickThrough,EnableForInternalSenders >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.8 Ensure the Advanced Threat Protection Safe Attachments policy is enabled" >> $filename
#Start-Sleep -Seconds 1.5
Get-SafeAttachmentRule >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.9 Ensure Basic Authentication for Exchange online is disabled" >> $filename
#Start-Sleep -Seconds 1.5
get-organizationconfig | format-table -auto name, OAuth* >> $filename
Write-Output "Verify that the policy is true." >> $filename
#Read-Host -Prompt "Press any key to continue"
Get-User -ResultSize Unlimited | Select-Object UserPrincipalName, AuthenticationPolicy | Where-Object -Property AuthenticationPolicy -ne $null >> $filename
Write-Output "Verify no user has a different authentication policy set.  If it doesn't return anything, then no user has that property set." >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.10 Ensure that an anti-phishing policy has been created" >> $filename
#Start-Sleep -Seconds 1.5
Get-AntiPhishPolicy | Select-Object -property ID >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.11 Ensure that DKIM is enabled for all Exchange Online Domains" >> $filename
#Start-Sleep -Seconds 1.5
Get-DkimSigningConfig >> $filename
Get-DkimSigningConfig
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.12 Ensure SPF Records are published for Exchange domains." >> $filename
#Start-Sleep -Seconds 1.5
nslookup -type=txt $Dom >> $filename
Write-Output "Verify there is an entry for SPF." >> $filename
$addDomyn = Read-Host -Prompt "Are there additional domains?  Y or N?"
if ($addDomyn -eq 'y')
{
    do {
        $addDom = Read-Host -Prompt "Enter additional mail domains to search."
        nslookup -type=txt $addDom >> $filename
        $quit = Read-Host -Prompt "Do you have any other domains to search?  Y or N?"
        } while ($quit -eq 'y')
}
#Read-Host -prompt "Press any key to continue"

Write-Output "4.13 Ensure DMARC Records for all Exchange Online domains are published" >> $filename
nslookup -type=txt _dmarc.$Dom >> $filename
Write-Output "Verify there is an entry for v=DMARC1." >> $filename
$addDomyn = Read-Host -Prompt "Are there additional domains?  Y or N?"
if ($addDomyn -eq 'y')
{
    do {
        $addDom = Read-Host -Prompt "Enter additional mail domains to search."
        nslookup -type=txt _dmarc.$addDom >> $filename
        $quit = Read-Host -Prompt "Do you have any other domains to search?  Y or N?"
        } while ($quit -eq 'y')
}
#Read-Host -prompt "Press any key to continue"

Write-Output "4.14 Ensure notifications for internal users sending malware is Enabled" >> $filename
#Start-Sleep -Seconds 1.5
Get-MalwareFilterPolicy | Select-Object -Property ID,EnableInternalSenderAdminNotifications,InternalSenderAdminAddress >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.15 Ensure Mailtips are enabled for end users" >> $filename
#Start-Sleep -Seconds 1.5
Get-OrganizationConfig | Select-Object MailTipsAllTipsEnabled, MailTipsExternalRecipientsTipsEnabled, MailTipsGroupMetricsEnabled, MailTipsLargeAudienceThreshold >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.16 Set spam policy to quarantine messages - not deliver to junk mail" >> $filename
#Start-Sleep -Seconds 1.5
Get-HostedContentFilterRule >> $filename
Get-HostedContentFilterPolicy | Select-Object -property ID,SpamAction,PhishSpamAction,BulkSpamAction,HighConfidencePhishAction >> $filename
Write-Output "Verify that the policies with the same name as the rules have the appropriate settings." >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.17 SMTP AUTH SHALL be disabled." >> $filename
#Start-Sleep -Seconds 1.5
Get-TransportConfig | Format-List SmtpClientAuthenticationDisabled >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.18 Email Encryption Policy is Configured" >> $filename
#Start-Sleep -Seconds 1.5
Get-IRMConfiguration | Select-Object -Property AzureRMSLicensingEnabled >> $filename
Get-TransportRule
#Read-Host -Prompt "Press any key to continue"

Write-Output "4.19 Enhanced Filtering is turned on for 3rd Party email filtering tools" >> $filename
#Start-Sleep -Seconds 1.5
Get-InboundConnector | Select-Object -Property Name,EFSkipLastIP,EFSkipIPs >> $filename
#Read-Host -Prompt "Press any key to continue"

