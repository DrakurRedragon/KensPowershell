Write-Host "6.1 Ensure document sharing is being controlled by domains with allow list or deny list"
Start-Sleep -Seconds 1.5
Get-SPOTenant | Select-Object -Property SharingAllowedDomainList, SharingBlockedDomainList, SharingdomainRestrictionMode
Read-Host -Prompt "Press any key to continue"

Write-Host "6.2 Block OneDrive for Business sync from unmanaged devices"
Start-Sleep -Seconds 1.5
Get-SPOTenantSyncClientRestriction | Select-Object -Property TenantRestrictionEnabled, AllowedDomainList
Read-Host -Prompt "Press any key to continue"

Write-Host "6.3 Ensure expiration time for external sharing links is set"
Start-Sleep -Seconds 1.5
Get-SPOTenant | Select-Object -Property ExternalUserExpirationRequired, ExternalUserExpireInDays
Read-Host -Prompt "Press any key to continue"

Write-Host "6.4 Ensure external storage providers available in Outlook on the Web are restricted"
Start-Sleep -Seconds 1.5
Get-OwaMailboxPolicy | Format-Table Name, AdditionalStorageProvidersAvailable
Read-Host -Prompt "Press any key to continue"

Write-Host "6.5 File and Folder Links default Sharing Settings SHALL be set to 'Specific People'"
Start-Sleep -Seconds 1.5
Get-SPOTenant | Select-Object -Property DefaultSharingLinkType
Read-Host -Prompt "Press any key to continue"

Write-Host "6.6.1 Anyone Links SHOULD be turned Off"
Start-Sleep -Seconds 1.5
Get-SPOTenant | Select-Object -Property SharingCapability
Write-Host "If the Value is ExternalUserandGuestSharing, it allows Anyone links,"
Read-Host -Prompt "Press any key to continue"

Write-Host "6.6.2 If Enabled, Anyone Links SHOULD be set to View by default"
Start-Sleep -Seconds 1.5
Get-SPOTenant | Select-Object -Property FileAnonymousLinkType, FolderAnonymousLinkType
Read-Host -Prompt "Press any key to continue"

Write-Host "6.7 Users SHALL Be Prevented from Running Custom Scripts"
Start-Sleep -Seconds 1.5
Get-SPOSite -identity https://$adminsite.sharepoint.com | Select-Object -Property DenyAddAndCustomizePages
Write-Host "This setting should be Enabled.  That means it is denying the custom scripts from running."
Read-Host -Prompt "Press any key to continue"

