# =============================================
# This is a continuation of the 1.x questions, Modern Authentication.
# =============================================
# This section is complete.
# =============================================

Write-Output "1.2 Ensure Modern Authentication for Exchange Online is Enabled and 4.9 Ensure Basic Authentication for Exchange online is disabled" >> $filename
#Start-Sleep -Seconds 1.5
get-organizationconfig | format-table -auto name, OAuth* >> $filename
Write-Output "Verify that the policy is true." >> $filename
#Read-Host -Prompt "Press any key to continue"

Get-User -ResultSize Unlimited | Select-Object UserPrincipalName, AuthenticationPolicy | Where-Object -Property AuthenticationPolicy -ne $null >> $filename
Write-Output "Verify no user has a different authentication policy set.  If it doesn't return anything, then no user has that property set." >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "1.3 Ensure Modern Authentication for SharePoint Applications is required. >> $filename"
Get-SPOTenant | Select-Object LegacyAuthProtocolsEnabled >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "1.4 Microsoft 365 Passwords are set not to expire.  Validity period of 2147483647 means this is set." >> $filename
get-msolpasswordpolicy -domain $Dom >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "1.5 Password Minimum Requirements, 12+ characters" >> $filename
Get-ADDefaultDomainPasswordPolicy >> $filename
#Read-Host -Prompt "Press any key to continue"

# =============================================
# This is the 2.x series of questions, Application Permissions
# =============================================

Write-Output "2.2 Ensure Calendar Details sharing with External Users is disabled." >> $filename
#Start-Sleep -Seconds 1.5
get-SharingPolicy | Where-object -property Default -eq True | Format-List -Property Domains >> $filename
Write-Output -Prompt "Look for Anonymous: in the Domains list.  If it is present and has any properties, external sharing is not disabled." >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "2.3 Ensure Defender for Office 365 SafeLinks for Office Applications is enabled." >> $filename
#Start-Sleep -Seconds 1.5
get-safelinkspolicy | select-object -property ID,EnableSafeLinksforEmail,EnableSafeLinksforTeams,EnableSafeLinksforOffice >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "2.4 Ensure Defender for Office 365 for SharePoint, OneDrive, and Microsoft Teams is Enabled" >> $filename
#Start-Sleep -Seconds 1.5
get-atppolicyforo365 | select-object -property ID,EnableATPForSPOTeamsODB,EnableSafeDocs >> $filename
#Read-Host -Prompt "Press any key to continue"

Write-Output "2.5 Ensure Office 365 SharePoint Infected files are disallowed for download." >> $filename
#Start-Sleep -Seconds 1.5
Get-SPOTenant | Select-Object DisallowInfectedFileDownload >> $filename
#Read-Host -Prompt "Press any key to continue"

# 2.6 Ensure user consent to apps accessing company data on their behalf is not allowed

# 2.7 Ensure the admin consent workflow is enabled

Write-Output "2.8 Ensure users installing Outlook add-ins is not allowedge." >> $filename
#Start-Sleep -Seconds 1.5
Get-RoleAssignmentPolicy | Where-Object -property Name -eq "Default Role Assignment Policy" | Select-Object -ExpandProperty AssignedRoles >> $filename
Write-Output "Verify that My Custom Apps, My Marketplace Apps, and My ReadWriteMailbox Apps are NOT present in the list." >> $filename
#Read-Host -Prompt "Press any key to continue"

# 2.9 Ensure users installing Word, Excel, Powerpoint is not allowed.

# 2.10 Ensure Internal Phishing for Forms is enabled.

# 2.11 Ensure that Sways cannot be shared with people outside the organization

